# Portal Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for AI features)
# You can also enter this in the Web UI instead
OPENAI_API_KEY=your_api_key_here

# Workspace directory (default: /workspace)
# WORKSPACE_DIR=/workspace

# Sub-agent configuration (background tasks)
# Model to use for sub-agents (default: gpt-4o-mini)
# AGENT_MODEL=gpt-4o-mini

# API key for sub-agents (defaults to OPENAI_API_KEY if not set)
# For OpenRouter, use your OpenRouter API key here
# AGENT_API_KEY=your_agent_api_key

# Base URL for sub-agent API calls (default: OpenAI)
# For OpenRouter: https://openrouter.ai/api/v1/chat/completions
# AGENT_BASE_URL=https://api.openai.com/v1/chat/completions
