# Portal Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for AI features)
# You can also enter this in the Web UI instead
OPENAI_API_KEY=your_api_key_here

# OpenRouter API Key (required for OpenRouter models in streaming mode)
# Get yours at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Workspace directory (default: /workspace)
# WORKSPACE_DIR=/workspace

# Sub-agent configuration (background tasks)
# Model to use for sub-agents (default: xiaomi/mimo-v2.5 via OpenRouter)
# AGENT_MODEL=xiaomi/mimo-v2.5

# API key for sub-agents (defaults to OPENAI_API_KEY if not set)
# For OpenRouter, use your OpenRouter API key here
# AGENT_API_KEY=your_agent_api_key

# Base URL for sub-agent API calls (default: OpenRouter)
# For OpenAI: https://api.openai.com/v1
# AGENT_BASE_URL=https://openrouter.ai/api/v1
